# Build rules for the OpenAFS util test suite.

srcdir=@srcdir@
abs_top_builddir=@abs_top_builddir@
include @TOP_OBJDIR@/src/config/Makefile.config
include @TOP_OBJDIR@/src/config/Makefile.lwp

MODULE_CFLAGS = -I$(TOP_OBJDIR) -I$(abs_top_builddir)/src/bozo

LIBS = ../tap/libtap.a \
       $(abs_top_builddir)/lib/util.a \
       $(abs_top_builddir)/lib/libopr.a

tests = bnode-t

all check test tests: $(tests)

bnode-t: bnode-t.o $(LIBS)
	$(LT_LDRULE) bnode-t.o $(LIBS) $(XLIBS)

install:

clean distclean:
	$(LT_CLEAN)
	$(RM) -f $(tests) *.o core