
srcdir=@srcdir@
bozo_srcdir=$(srcdir)/../../src/bozo
abs_top_builddir=@abs_top_builddir@
include @TOP_OBJDIR@/src/config/Makefile.config
include @TOP_OBJDIR@/src/config/Makefile.lwp

BINS = bnode-t bosconfig-t

MODULE_CFLAGS = \
  -I$(TOP_OBJDIR) \
  -I$(srcdir)/../common/ \
  -I$(bozo_srcdir)

# Note: libauth is only needed due to a bug in libafstest.
MODULE_LIBS = \
  $(abs_top_builddir)/tests/common/libafstest_common.la \
  $(abs_top_builddir)/lib/util.a \
  $(abs_top_builddir)/lib/libopr.a \
  $(abs_top_builddir)/lib/liblwp.a \
  $(abs_top_builddir)/lib/libprocmgmt.a \
  $(XLIBS)

all check test tests: $(BINS)

runtests: $(BINS)
	./bosconfig-t

bnode-t: bnode-t.o bnode.o
	$(LT_LDRULE_static) bnode-t.o bnode.o $(MODULE_LIBS)

bosconfig-t: bosconfig-t.o bnode.o bosconfig.o
	$(LT_LDRULE_static) bosconfig-t.o bnode.o bosconfig.o $(MODULE_LIBS)

bnode.o: $(bozo_srcdir)/bnode.c
	$(AFS_CCRULE) -o bnode.o $(bozo_srcdir)/bnode.c

bosconfig.o: $(bozo_srcdir)/bosconfig.c
	$(AFS_CCRULE) -o bosconfig.o $(bozo_srcdir)/bosconfig.c

clean:
	$(LT_CLEAN)
	rm -f *.o *.cs.c *.ss.c *.xdr.c test.h $(BINS)
